rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: presentations
    // Document ID: auto-generated
    // Fields:
    //   - borrowerName: string (required)
    //   - propertyAddress: string (optional)
    //   - borrowerEmail: string (optional)
    //   - originalBalance: number (required)
    //   - originationMonth: number (required)
    //   - originationYear: number (required)
    //   - originalTerm: number (required)
    //   - existingRate: number (required)
    //   - newRate: number (required)
    //   - newTerm: number (required)
    //   - selectedState: string (required)
    //   - pointsType: string (required)
    //   - pointsValue: number (required)
    //   - hasOriginalTitlePolicy: bool (required)
    //   - financeClosingCosts: bool (required)
    //   - savingsYears: number (required)
    //   - wealthRate: number (required)
    //   - wealthToggle: string (required)
    //   - manualCurrentBalance: number (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - createdBy: string (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - displayName: string (required)
    //   - companyName: string (optional)
    //   - companyAddress: string (optional)
    //   - nmlsNumber: string (optional)
    //   - email: string (required)
    //   - phone: string (optional)
    //   - website: string (optional)
    //   - headshotUrl: string (optional)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "derekfertig@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPresentation(data) {
      return data.borrowerName is string && data.borrowerName.size() >= 0 && data.borrowerName.size() < 100 &&
             (!('propertyAddress' in data) || (data.propertyAddress is string && data.propertyAddress.size() < 200)) &&
             (!('borrowerEmail' in data) || (data.borrowerEmail is string && data.borrowerEmail.size() < 100)) &&
             data.originalBalance is number && data.originalBalance >= 0 &&
             data.newRate is number && data.newRate >= 0 &&
             data.createdAt is timestamp &&
             data.createdBy is string && data.createdBy == request.auth.uid;
    }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!('companyName' in data) || (data.companyName is string && data.companyName.size() < 100)) &&
             (!('companyAddress' in data) || (data.companyAddress is string && data.companyAddress.size() < 200)) &&
             (!('nmlsNumber' in data) || (data.nmlsNumber is string && data.nmlsNumber.size() < 50)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 50)) &&
             (!('website' in data) || (data.website is string && data.website.size() < 200)) &&
             (!('headshotUrl' in data) || (data.headshotUrl is string && data.headshotUrl.size() < 1000));
    }

    match /presentations/{presentationId} {
      // Allow anyone to read a presentation if they have the ID (shared link)
      // In a more secure app, we might add a password or expiration
      allow read: if true;
      
      // Only authenticated users can create/update their own presentations
      allow create: if isAuthenticated() && isValidPresentation(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.createdBy) && isValidPresentation(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.createdBy);
    }

    match /users/{userId} {
      // Allow anyone to read profiles so clients can see LO info
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
